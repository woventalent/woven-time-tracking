# ── Microsoft SSO (Azure AD) ──────────────────────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Add redirect URI: https://your-domain.com/auth/callback (or http://localhost:3000/auth/callback for local)
#
# Leave these unset to use dev-login mode (no SSO, simple email/name form)

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=woventalent.in
AUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Super Admin ───────────────────────────────────────────────────────────────
# The user with this email gets super_admin role (can create/manage all workspaces)
SUPER_ADMIN_EMAIL=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# If unset, assignment emails are silently skipped
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@woventalent.in

# ── App URL ───────────────────────────────────────────────────────────────────
APP_URL=https://your-production-domain.example.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development      # set to 'production' for secure cookies
